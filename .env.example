FLASK_ENV=development
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=weknora_python

SECRET_KEY=change-this-in-production
JWT_SECRET_KEY=change-this-in-production
JWT_EXPIRES_HOURS=8

AUTH_PROVIDER=local
AUTH_ALLOW_LOCAL_FALLBACK=true

# LDAP/AD (optional; keep disabled for local-only environments)
LDAP_ENABLED=false
LDAP_SERVER_URI=ldap://127.0.0.1:389
LDAP_USE_SSL=false
LDAP_CONNECT_TIMEOUT=8
LDAP_SEARCH_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER_TEMPLATE=(sAMAccountName={account})
LDAP_ACCOUNT_DOMAIN=
LDAP_USER_ATTRIBUTES=["objectSid","sAMAccountName","displayName","cn","mail","department"]
LDAP_AUTO_CREATE_USER=true
LDAP_SYNC_FULL_NAME=true
LDAP_SYNC_EMAIL=true
LDAP_SYNC_DEPARTMENT=true
LDAP_AUTO_CREATE_DEPARTMENT=false
LDAP_DEFAULT_ROLE_LEVEL=user

WEKNORA_BASE_URL=http://127.0.0.1:8080/api/v1
WEKNORA_API_KEY=

# ===== WeKnora KB defaults =====
# These settings are applied when creating knowledge base from weknora-python.
WEKNORA_KB_DEFAULT_TYPE=document
WEKNORA_KB_DEFAULT_EMBEDDING_MODEL_ID=
WEKNORA_KB_DEFAULT_SUMMARY_MODEL_ID=
WEKNORA_KB_DEFAULT_VLM_MODEL_ID=

WEKNORA_KB_CHUNK_SIZE=1000
WEKNORA_KB_CHUNK_OVERLAP=200
WEKNORA_KB_ENABLE_MULTIMODAL=true
WEKNORA_KB_ENABLE_PARENT_CHILD=false
WEKNORA_KB_PARENT_CHUNK_SIZE=4096
WEKNORA_KB_CHILD_CHUNK_SIZE=384
WEKNORA_KB_SEPARATORS=["\\n\\n","\\n","。","！","？",";","；"]
# Example: [{"file_types":[".pdf",".docx"],"engine":"builtin"}]
WEKNORA_KB_PARSER_ENGINE_RULES=[]

WEKNORA_KB_STORAGE_PROVIDER=local

WEKNORA_KB_ASR_ENABLED=false
WEKNORA_KB_ASR_MODEL_ID=
WEKNORA_KB_ASR_LANGUAGE=

WEKNORA_KB_QUESTION_GENERATION_ENABLED=false
WEKNORA_KB_QUESTION_COUNT=3

# Reserved for future chat/agent default mapping.
WEKNORA_CHAT_DEFAULT_MODEL_ID=
WEKNORA_CHAT_DEFAULT_RERANK_MODEL_ID=
WEKNORA_AGENT_QUICK_ANSWER_ID=builtin-quick-answer
WEKNORA_AGENT_SMART_REASONING_ID=builtin-smart-reasoning
